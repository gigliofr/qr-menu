# File e cartelle da escludere dal deployment

# Version Control
.git
.gitignore
.github

# IDE
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Build artifacts
*.exe
*.dll
*.so
*.dylib
qr-menu.exe

# Testing
*_test.go
*.test
coverage.out

# Dependencies (scaricate durante build)
vendor/

# OS specifici
node_modules/
.env.local
.env.*.local

# Documentazione (non necessaria per runtime)
*.md
docs/

# Mobile/Flutter
mobile/build/
mobile/.dart_tool/
mobile/pubspec.lock

# Backup e temporanei
*.bak
*.tmp
*.swp

# Secrets (non deployare!)
*.pem
*.key
.env

# Cache
.cache/
tmp/

# Questo esclude tutto tranne quello che serve
# (Dockerfile, go.mod, go.sum, *.go, web/favicon.svg)
